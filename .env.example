# ─────────────────────────────────────────────────────────────────
# TalentLens — Environment Variables
# Copy this file to .env.local and fill in your values.
# ─────────────────────────────────────────────────────────────────

# ── Data Source ──────────────────────────────────────────────────
# Set to 'true' to use in-memory mock data (no backend required).
# Set to 'false' to use the real Next.js API routes at /api/*.
NEXT_PUBLIC_USE_MOCK=true

# External backend URL (optional).
# Leave empty to use the built-in Next.js API routes (/api/*).
# Only required if you are running a separate backend service.
NEXT_PUBLIC_API_URL=

# ── AI (Anthropic Claude) ─────────────────────────────────────────
# Required for AI candidate chat, scoring summaries, and WhatsApp
# draft generation. Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-...

# Claude model to use for AI features.
# Options: claude-sonnet-4-6 | claude-opus-4-6 | claude-haiku-4-5-20251001
# Default: claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── WhatsApp Business API ─────────────────────────────────────────
# Required to send and receive real WhatsApp messages.
# Obtain from Meta Business Suite → WhatsApp → API Setup.

# Permanent access token from your Meta App.
WHATSAPP_ACCESS_TOKEN=EAAx...

# The numeric Phone Number ID from WhatsApp → API Setup.
WHATSAPP_PHONE_NUMBER_ID=123456789012345

# A secret string you choose; used to verify webhook callbacks.
WHATSAPP_VERIFY_TOKEN=my_custom_verify_token

# ── File Storage (optional) ──────────────────────────────────────
# If using cloud storage for uploaded CV files:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=eu-west-1

# ── Authentication (optional — add NextAuth when ready) ──────────
# NEXTAUTH_SECRET=generate-with: openssl rand -base64 32
# NEXTAUTH_URL=http://localhost:3000
