# ══════════════════════════════════════════════════════════════════════════════
# TalentLens — Environment Variables
# Copy to .env and fill in your values
# ══════════════════════════════════════════════════════════════════════════════

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000         # Backend API base URL

# ─── Backend Core ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://talentlens:password@localhost:5432/talentlens
SECRET_KEY=change-me-to-a-random-32-char-string  # JWT signing key
CORS_ORIGINS=http://localhost:3000               # Comma-separated allowed origins
DEBUG=true

# ─── AI Configuration (Single Unified Provider) ──────────────────────────────
# All AI features (extraction, scoring, chat) use this one provider.
# Switch between providers by changing these values or via the Settings page.
#
# OpenRouter (DEFAULT — recommended, access 200+ models with one API key):
AI_PROVIDER=openrouter                           # openrouter | openai | anthropic | ollama | custom
AI_API_KEY=sk-or-v1-your-key-here                # Get key at https://openrouter.ai/keys
AI_API_BASE_URL=https://openrouter.ai/api/v1     # OpenRouter endpoint
AI_MODEL=openai/gpt-4o                           # Model (provider/model format)
AI_EMBEDDING_MODEL=openai/text-embedding-3-small # Embedding model
AI_HTTP_REFERER=http://localhost:3000             # Required by OpenRouter
AI_SITE_NAME=TalentLens                          # Required by OpenRouter
#
# OpenAI (direct):
# AI_PROVIDER=openai
# AI_API_KEY=sk-your-key-here
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_MODEL=gpt-4o
# AI_EMBEDDING_MODEL=text-embedding-3-small
#
# Ollama (local, free):
# AI_PROVIDER=ollama
# AI_API_KEY=ollama                              # Not used but required
# AI_API_BASE_URL=http://localhost:11434/v1
# AI_MODEL=qwen2.5:7b
# AI_EMBEDDING_MODEL=nomic-embed-text
#
# Anthropic:
# AI_PROVIDER=anthropic
# AI_API_KEY=sk-ant-your-key-here
# AI_API_BASE_URL=https://api.anthropic.com/v1
# AI_MODEL=claude-sonnet-4-20250514
# AI_EMBEDDING_MODEL=text-embedding-3-small

# ─── File Storage ─────────────────────────────────────────────────────────────
STORAGE_BACKEND=local                            # local | s3
UPLOAD_DIR=./uploads                             # Local upload directory

# ─── Monitoring (Optional) ───────────────────────────────────────────────────
# LANGSMITH_API_KEY=                              # LangSmith tracing
# LANGSMITH_PROJECT=talentlens

# ══════════════════════════════════════════════════════════════════════════════
# FUTURE UPGRADES — Uncomment when adding these services
# ══════════════════════════════════════════════════════════════════════════════

# ─── Redis (Job Queue) ───────────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379

# ─── Qdrant (Vector Store — replaces pgvector) ──────────────────────────────
# QDRANT_URL=http://localhost:6333

# ─── Neo4j (Knowledge Graph) ────────────────────────────────────────────────
# NEO4J_URL=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=password

# ─── WhatsApp Business API ──────────────────────────────────────────────────
# WHATSAPP_API_TOKEN=                             # Meta access token
# WHATSAPP_PHONE_ID=                              # Phone number ID
# WHATSAPP_VERIFY_TOKEN=                          # Webhook verify token
# WHATSAPP_BUSINESS_ACCOUNT_ID=                   # Business account ID

# ─── S3 Storage (Alternative to local) ──────────────────────────────────────
# S3_ENDPOINT=                                    # DigitalOcean Spaces / AWS S3 endpoint
# S3_BUCKET=                                      # Bucket name
# S3_ACCESS_KEY=                                  # Access key
# S3_SECRET_KEY=                                  # Secret key
